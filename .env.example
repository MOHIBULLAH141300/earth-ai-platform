ENVIRONMENT=development

# ========== API Configuration ==========
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
DEBUG=False

# ========== Frontend Configuration ==========
REACT_APP_API_URL=http://localhost:8000/api
REACT_APP_WS_URL=ws://localhost:8000

# ========== Database Configuration ==========
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=earthai
POSTGRES_USER=earthai
POSTGRES_PASSWORD=change-me

# ========== Redis Configuration ==========
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ========== Celery Configuration ==========
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ========== Google Earth Engine Configuration ==========
EARTHAI_GEE_PROJECT_ID=
EARTHAI_SENTINEL_CLIENT_ID=
EARTHAI_SENTINEL_CLIENT_SECRET=
EARTHAI_NASA_TOKEN=

# ========== Literature Scraping Configuration ==========
ARXIV_BATCH_SIZE=50
ARXIV_UPDATE_INTERVAL=86400

DOAJ_BATCH_SIZE=50

# ========== NLP Configuration ==========
NLP_MODEL_NAME=facebook/bart-large-mnli
NLP_DEVICE=cpu

# ========== Model Configuration ==========
MODEL_DEFAULT_FRAMEWORK=pytorch
MODEL_DEVICE=cpu
MODEL_CACHE_DIR=./models/cache

# ========== Monitoring Configuration ==========
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=change-me

# ========== Logging Configuration ==========
LOG_LEVEL=INFO
LOG_FILE=./logs/earthai_platform.log

# ========== Task Configuration ==========
MAX_CONCURRENT_TASKS=3
TASK_TIMEOUT=3600
TASK_RETRY_COUNT=3

# ========== API Security ==========
EARTHAI_API_SECRET_KEY=change-me

# ========== Feature Flags ==========
ENABLE_CHATBOT=True
ENABLE_LITERATURE_SCRAPING=True
ENABLE_AUTO_ML=True
ENABLE_RL_ADAPTATION=True
ENABLE_ENSEMBLE=True
ENABLE_MONITORING=True
ENABLE_CACHING=True

# ========== Research Database ==========
RESEARCH_DB_PATH=./data/research_knowledge.db
RESEARCH_MAX_PAPERS=50000

# ========== MLflow Configuration ==========
MLFLOW_TRACKING_URI=http://mlflow:5000
