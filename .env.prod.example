# EarthAI Platform - Production Environment Variables
# Copy this to .env and fill in your values

# ==========================================
# APPLICATION SETTINGS
# ==========================================

# Environment (development/production)
ENVIRONMENT=production

# Secret key for JWT tokens and encryption
SECRET_KEY=your-super-secret-key-change-this-in-production

# ==========================================
# DATABASE SETTINGS
# ==========================================

# PostgreSQL connection URL
DATABASE_URL=postgresql://earthai:your-password@postgres:5432/earthai

# PostgreSQL password (Railway will provide this)
POSTGRES_PASSWORD=your-postgres-password

# ==========================================
# REDIS SETTINGS
# ==========================================

# Redis connection URL
REDIS_URL=redis://redis:6379/0

# ==========================================
# EXTERNAL URLS
# ==========================================

# Frontend URL (your Railway domain)
FRONTEND_URL=https://your-app.railway.app

# API URL (your Railway domain + /api)
API_URL=https://your-app.railway.app/api

# WebSocket URL
WS_URL=wss://your-app.railway.app

# ==========================================
# PORT SETTINGS
# ==========================================

# API server port
PORT=8000

# Frontend port
FRONTEND_PORT=3000

# ==========================================
# MONITORING & LOGGING
# ==========================================

# Log level (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# Enable Prometheus metrics
PROMETHEUS_ENABLED=true

# ==========================================
# AI/ML SETTINGS
# ==========================================

# OpenAI API Key (if using OpenAI models)
OPENAI_API_KEY=your-openai-api-key

# HuggingFace API Token (if using HuggingFace models)
HUGGINGFACE_API_TOKEN=your-huggingface-token

# ==========================================
# EMAIL SETTINGS (Optional)
# ==========================================

# SMTP server for notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ==========================================
# SECURITY SETTINGS
# ==========================================

# CORS allowed origins
CORS_ORIGINS=https://your-app.railway.app,https://www.your-domain.com

# JWT token expiration (hours)
JWT_EXPIRE_HOURS=24

# ==========================================
# RAILWAY SPECIFIC
# ==========================================

# Railway provides these automatically:
# - DATABASE_URL
# - REDIS_URL
# - POSTGRES_PASSWORD
# Just set SECRET_KEY and FRONTEND_URL manually